DB__NAME="faq_bot_db"
DB__USER="postgres"
DB__PASSWORD="password"
DB__HOST="localhost"

DB_SCHEMA__QUESTION_TEXT_MAX_LEN=384
DB_SCHEMA__ANSWER_TEXT_MAX_LEN=384
DB_SCHEMA__QUESTION_EMBEDDING_DIM=256

SUGGESTION__SEARCH__BEST_MATCH_THRESHOLD=0.7
SUGGESTION__SEARCH__BEST_MATCH_MARGIN=0.05
SUGGESTION__SEARCH__RELATED_THRESHOLD=0.6
SUGGESTION__SEARCH__OBVIOUS_MARGIN=0.3

SUGGESTION__RERANK__ENABLED=True

SUGGESTION__COMPOSE__ENABLED=True
SUGGESTION__COMPOSE__SUPPORTING_MARGIN=0.15
SUGGESTION__COMPOSE__SUPPORTING_TOP_K=2

SUGGESTION__GENERATION__ENABLED=True
SUGGESTION__GENERATION__MAX_AMOUNT=16

CLIENTS__EMBEDDING__TIMEOUT=5
CLIENTS__EMBEDDING__RETRIES=1
CLIENTS__EMBEDDING__RETRY_DELAY=0.2

CLIENTS__RERANK__TIMEOUT=5
CLIENTS__RERANK__RETRIES=1
CLIENTS__RERANK__RETRY_DELAY=0.2

CLIENTS__COMPOSE__TIMEOUT=5
CLIENTS__COMPOSE__RETRIES=1
CLIENTS__COMPOSE__RETRY_DELAY=0.2

CLIENTS__GENERATION__TIMEOUT=5
CLIENTS__GENERATION__RETRIES=1
CLIENTS__GENERATION__RETRY_DELAY=0.2

ADMIN__IDS=[123456789]

API__HOST="0.0.0.0"
API__PORT=8000

# Yandex Cloud API credentials used by request templates
# (embedding/rerank/compose/generation in default config)
REQUESTS__FOLDER_ID="YOUR_FOLDER_ID"
REQUESTS__IAM_TOKEN="YOUR_IAM_TOKEN"
