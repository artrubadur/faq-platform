# Docker Compose interpolation only.
# Runtime service settings live in:
# - env/bot.env
# - env/orchestrator.env

COMPOSE__LOGGING_PATH="./config/logging.yml"
COMPOSE__REDIS_CONFIG_PATH="./config/bot/redis.conf"
COMPOSE__ORCHESTRATOR_REQUESTS_PATH="./config/orchestrator/requests.yml"
COMPOSE__BOT_CONSTANTS_PATH="./config/bot/constants.example.yml"
COMPOSE__BOT_MESSAGES_PATH="./config/bot/messages.example.yml"
COMPOSE__BOT_COMMANDS_PATH="./config/bot/commands.example.yml"
# Optional: host path to a PEM certificate uploaded in setWebhook.
# Default fallback is ./config/bot/webhook.pem when value is empty or missing.
COMPOSE__BOT_CERTIFICATE_PATH=
